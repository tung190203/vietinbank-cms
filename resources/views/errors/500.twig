{% extends "admin.index" %}

{% block title %}Oops! Something went wrong.{% endblock %}

{% block breadcrumb %}
	<li class="breadcrumb-item active">500</li>
{% endblock %}

{% block content %}

<div class="error-page">
	<h2 class="headline text-red">500</h2>

	<div class="error-content">
		<h3>Oops! Something went wrong.</h3>
		<p>We will work on fixing that right away.</p>
		<div>{{ exception }}</div>
	</div>
</div>

{% endblock %}